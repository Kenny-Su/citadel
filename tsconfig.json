{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@citadel/platform/app": ["src/platform/app.ts"],
      "@citadel/platform/client": ["src/platform/client.ts"],
      "@citadel/platform/server-app": ["src/platform/serverApp.ts"],
      "@citadel/platform/persistence": ["src/platform/persistence.ts"],
      "@citadel/apps/catalog": ["src/apps/catalog.ts"],
      "@citadel/apps/chat": ["src/apps/chat/index.ts"],
      "@citadel/apps/chat/client": ["src/apps/chat/client.tsx"],
      "@citadel/apps/chat/server": ["src/apps/chat/serverEntry.ts"],
      "@citadel/apps/chess": ["src/apps/chess/index.ts"],
      "@citadel/apps/chess/client": ["src/apps/chess/client.tsx"],
      "@citadel/apps/chess/server": ["src/apps/chess/serverEntry.ts"],
      "@citadel/apps/snake": ["src/apps/snake/index.ts"],
      "@citadel/apps/snake/client": ["src/apps/snake/client.tsx"],
      "@citadel/apps/snake/server": ["src/apps/snake/serverEntry.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src/client", "src/shared", "vitest.setup.ts"]
}
